#!/usr/bin/env bash
set -euo pipefail

CLAUDE_BIN="${CLAUDE_BIN:-${HOME}/.local/bin/claude}"
if [[ ! -x "$CLAUDE_BIN" ]]; then
  CLAUDE_BIN="$(command -v claude 2>/dev/null || true)"
fi
if [[ -z "$CLAUDE_BIN" || ! -x "$CLAUDE_BIN" ]]; then
  printf 'claude: unable to find executable claude binary. Set CLAUDE_BIN=/path/to/claude.\n' >&2
  exit 127
fi

usage() {
  cat >&2 <<'EOF'
Usage:
  ./claude [--quiet] "prompt"

Options:
  --quiet, -q   Run `claude --print` once instead of launching the TUI.
  --help, -h    Show this help.

Use ./repeat --agent claude --prompt "..." for recurring unattended runs.
EOF
}

QUIET=0
claude_args=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --quiet|-q)
      QUIET=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    --)
      shift
      claude_args+=("$@")
      break
      ;;
    *)
      claude_args+=("$1")
      shift
      ;;
  esac
done

if [[ ${#claude_args[@]} -eq 0 ]]; then
  usage
  exit 2
fi

if [[ "$QUIET" -eq 1 ]]; then
  exec "$CLAUDE_BIN" --print --output-format text "${claude_args[@]}"
fi

exec "$CLAUDE_BIN" "${claude_args[@]}"
