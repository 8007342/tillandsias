    <h4 tabindex="-1" id="F.SkipNow" data-kind="method" class="Documentation-typeMethodHeader">
      <span>func (*F) <a class="Documentation-source" href="https://cs.opensource.google/go/go/+/go1.26.2:src/testing/testing.go;l=1253">SkipNow</a> <a class="Documentation-idLink" href="#F.SkipNow" title="Go to F.SkipNow" aria-label="Go to F.SkipNow">¶</a></span>
  <span class="Documentation-sinceVersion">
    
