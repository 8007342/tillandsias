#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
Usage:
  ./repeat --prompt "<prompt>" [--times <n>] [--wait <duration>] [--timeout <duration>] [--agent <agents>]

Options:
  --prompt <prompt>      Required prompt for every fresh agent cycle.
  --times <n>           Optional positive integer cycle count. Omit to run forever.
  --wait <duration>     Sleep after a cycle completes and before the next starts. Default: 45m.
                         Forms: 45s, 30m, 2h, 1d, 2h30m, or raw seconds.
  --timeout <duration>  Hard cap on a single agent cycle. A hung harness (e.g. a
                         CLI stuck in a reconnect loop) is killed and the loop
                         moves on. Default: 90m. Use 0 to disable.
  --agent <agents>      claude, opencode, gemini, antigravity, codex, random
                         (claude/opencode/gemini/codex), or a comma-separated
                         subset (e.g. claude,opencode,codex) to temporarily
                         skip a harness that is down. One agent is chosen at
                         random per cycle. Default: random.
  --help, -h            Show this help.

Resilience: a failed or silent cycle (non-zero exit, timeout, or an exit-0 run
that produced no output -- the usual shape of a quota/auth failure) is logged as
a warning and the loop continues to the next cycle rather than tearing down. A
missing/non-executable harness binary still aborts, since retrying cannot help.

Each cycle starts a fresh FULL YOLO noninteractive agent session at the root of
the caller's Tillandsias Git worktree.
EOF
}

die() {
  printf 'repeat: %s\n' "$*" >&2
  exit 2
}

PROMPT=""
TIMES_COUNT=""
WAIT_INTERVAL="45m"
TIMEOUT_INTERVAL="90m"
AGENT="random"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --prompt)
      [[ $# -ge 2 ]] || die "--prompt requires a value"
      PROMPT="$2"
      shift 2
      ;;
    --times)
      [[ $# -ge 2 ]] || die "--times requires a positive integer"
      [[ "$2" =~ ^[0-9]+$ && "$2" -ge 1 ]] || die "--times requires a positive integer"
      TIMES_COUNT="$2"
      shift 2
      ;;
    --wait)
      [[ $# -ge 2 ]] || die "--wait requires a duration"
      WAIT_INTERVAL="$2"
      shift 2
      ;;
    --timeout)
      [[ $# -ge 2 ]] || die "--timeout requires a duration"
      TIMEOUT_INTERVAL="$2"
      shift 2
      ;;
    --agent)
      [[ $# -ge 2 ]] || die "--agent requires a value"
      AGENT="$2"
      shift 2
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    --)
      shift
      [[ $# -eq 0 ]] || die "unexpected positional arguments: $*"
      ;;
    *)
      die "unknown argument: $1"
      ;;
  esac
done

[[ -n "$PROMPT" ]] || { usage; die "--prompt is required"; }

# Tillandsias smoke hosts are designed for idempotent destructive runtime tests.
# Agents must treat Podman/VM/WSL resets as expected setup unless the operator
# explicitly overrides this for a non-smoke host.
export TILLANDSIAS_DESTRUCTIVE_RESET_OK="${TILLANDSIAS_DESTRUCTIVE_RESET_OK:-1}"

# --agent accepts a single agent, the keyword "random" (all four), or a
# comma-separated subset (e.g. claude,opencode,codex) to temporarily exclude a
# harness that is down. Each cycle picks one agent uniformly at random from the
# resolved set; a one-element set therefore always runs that agent.
declare -a AGENT_LIST=()
if [[ "$AGENT" == "random" ]]; then
  AGENT_LIST=(claude opencode gemini codex)
else
  IFS=',' read -r -a AGENT_LIST <<< "$AGENT"
fi

[[ "${#AGENT_LIST[@]}" -ge 1 ]] || die "--agent requires at least one agent"
for agent_name in "${AGENT_LIST[@]}"; do
  [[ -n "$agent_name" ]] || die "--agent has an empty entry (check for stray commas)"
  case "$agent_name" in
    claude|opencode|gemini|antigravity|codex) ;;
    random) die "--agent: 'random' cannot be combined in a list; use it alone for all agents" ;;
    *) die "--agent must be claude, opencode, antigravity, codex, random, or a comma-separated subset" ;;
  esac
done

CALLER_PWD="$(pwd -P)"
REPO_ROOT="$(git -C "$CALLER_PWD" rev-parse --show-toplevel 2>/dev/null || true)"
[[ -n "$REPO_ROOT" ]] || die "current directory is not inside a Git worktree"
cd "$REPO_ROOT"

duration_to_seconds() {
  local input="$1"
  local rest="$input"
  local total=0
  local number unit

  if [[ "$rest" =~ ^[0-9]+$ ]]; then
    [[ "$rest" -ge 1 ]] || die "duration must be greater than zero"
    printf '%s\n' "$rest"
    return 0
  fi

  while [[ -n "$rest" ]]; do
    if [[ "$rest" =~ ^([0-9]+)([smhd])(.*)$ ]]; then
      number="${BASH_REMATCH[1]}"
      unit="${BASH_REMATCH[2]}"
      rest="${BASH_REMATCH[3]}"
      case "$unit" in
        s) total=$((total + number)) ;;
        m) total=$((total + number * 60)) ;;
        h) total=$((total + number * 3600)) ;;
        d) total=$((total + number * 86400)) ;;
      esac
    else
      die "invalid duration '$input'; use 45m, 2h, 2h30m, 45s, 1d, or seconds"
    fi
  done

  [[ "$total" -ge 1 ]] || die "duration must be greater than zero"
  printf '%s\n' "$total"
}

timestamp_utc() {
  date -u '+%Y-%m-%dT%H:%M:%SZ'
}

resolve_bin() {
  local env_name="$1"
  local fallback="$2"
  local value="${!env_name:-}"
  if [[ -n "$value" ]]; then
    [[ -x "$value" ]] || { printf 'repeat: %s is not executable: %s\n' "$env_name" "$value" >&2; return 127; }
    printf '%s\n' "$value"
    return 0
  fi
  command -v "$fallback" 2>/dev/null || {
    printf 'repeat: unable to find %s; set %s=/path/to/%s\n' "$fallback" "$env_name" "$fallback" >&2
    return 127
  }
}

select_agent() {
  local index=$((RANDOM % ${#AGENT_LIST[@]}))
  printf '%s\n' "${AGENT_LIST[$index]}"
}

# Resolve a timeout(1) implementation once. GNU coreutils ships `timeout` on
# Linux; macOS ships neither it nor `gtimeout` unless coreutils is installed
# (`brew install coreutils`). When a binary is present we prefer it; otherwise
# run_with_timeout falls back to a portable bash watchdog. Empty means "fall
# back".
TIMEOUT_CMD=""
if command -v timeout >/dev/null 2>&1; then
  TIMEOUT_CMD="timeout"
elif command -v gtimeout >/dev/null 2>&1; then
  TIMEOUT_CMD="gtimeout"
fi

# run_with_timeout <command...> -- apply the per-cycle hard timeout so a harness
# wedged in a reconnect loop cannot hang the loop. Sends TERM at the deadline,
# KILL after a 30s grace window, and reports exit 124 on timeout (matching
# timeout(1)), which the caller treats as a non-fatal warning.
run_with_timeout() {
  if [[ "$TIMEOUT_SECONDS" -le 0 ]]; then
    "$@"
    return $?
  fi

  if [[ -n "$TIMEOUT_CMD" ]]; then
    "$TIMEOUT_CMD" --signal=TERM --kill-after=30s "$TIMEOUT_SECONDS" "$@"
    return $?
  fi

  # Portable fallback for hosts without a timeout(1) binary (stock macOS). A
  # marker file lets us distinguish a watchdog kill from an ordinary signal so
  # we can normalize the exit code to 124.
  local marker
  marker="$(mktemp)"
  "$@" &
  local cmd_pid=$!
  (
    sleep "$TIMEOUT_SECONDS"
    if kill -0 "$cmd_pid" 2>/dev/null; then
      printf 1 > "$marker"
      kill -TERM "$cmd_pid" 2>/dev/null
      # Poll the 30s grace window so the watchdog self-terminates the moment
      # the harness honors TERM, instead of always sleeping the full grace.
      g=0
      while [[ "$g" -lt 30 ]] && kill -0 "$cmd_pid" 2>/dev/null; do
        sleep 1
        g=$((g + 1))
      done
      kill -KILL "$cmd_pid" 2>/dev/null
    fi
  ) &
  local watcher_pid=$!

  local status=0
  wait "$cmd_pid" 2>/dev/null || status=$?

  # Cycle finished on its own: stop the watchdog so its sleep does not linger.
  kill -TERM "$watcher_pid" 2>/dev/null || true
  wait "$watcher_pid" 2>/dev/null || true

  if [[ "$(cat "$marker" 2>/dev/null)" == "1" ]]; then
    status=124
  fi
  rm -f "$marker"
  return "$status"
}

run_agent() {
  local selected="$1"
  local bin

  case "$selected" in
    codex)
      bin="$(resolve_bin CODEX_BIN codex)" || return $?
      run_with_timeout "$bin" exec --color never --dangerously-bypass-approvals-and-sandbox -p tillandsias -C "$REPO_ROOT" "$PROMPT"
      ;;
    claude)
      bin="$(resolve_bin CLAUDE_BIN claude)" || return $?
      run_with_timeout "$bin" --print --output-format text --dangerously-skip-permissions "$PROMPT" --add-dir "$REPO_ROOT"
      ;;
    opencode)
      bin="$(resolve_bin OPENCODE_BIN opencode)" || return $?
      (cd "$REPO_ROOT" && run_with_timeout "$bin" run --dangerously-skip-permissions "$PROMPT")
      ;;
    gemini)
      bin="$(resolve_bin GEMINI_BIN gemini)" || return $?
      (cd "$REPO_ROOT" && run_with_timeout "$bin" --prompt="$PROMPT" --yolo --include-directories "$REPO_ROOT")
      ;;
    antigravity)
      bin="$(resolve_bin ANTIGRAVITY_BIN agy)" || return $?
      # agy reads the prompt from stdin in print mode; piping it avoids the
      # variadic --add-dir parser swallowing the task text as another path.
      (cd "$REPO_ROOT" && printf '%s\n' "$PROMPT" | run_with_timeout "$bin" --print --dangerously-skip-permissions --add-dir "$REPO_ROOT")
      ;;
    *)
      die "internal error: unsupported selected agent '$selected'"
      ;;
  esac
}

WAIT_SECONDS="$(duration_to_seconds "$WAIT_INTERVAL")"
if [[ "$TIMEOUT_INTERVAL" == "0" ]]; then
  TIMEOUT_SECONDS=0
else
  TIMEOUT_SECONDS="$(duration_to_seconds "$TIMEOUT_INTERVAL")"
fi
CYCLE=0

while :; do
  CYCLE=$((CYCLE + 1))
  SELECTED_AGENT="$(select_agent)"
  printf '[repeat] %s cycle=%d agent=%s repo=%s start\n' "$(timestamp_utc)" "$CYCLE" "$SELECTED_AGENT" "$REPO_ROOT" >&2

  # Stream the cycle's output line-by-line so the operator sees progress live
  # (a plain `tee` buffers on macOS BSD, hiding real-time output). Also capture
  # to disk so we can measure how much was produced.
  # Many harnesses exit 0 even on quota/auth failure (e.g. agy returns 0 with
  # empty output on an HTTP 429); an empty successful run is the most reliable
  # cross-harness signal that the cycle did no work.
  CYCLE_OUTPUT="$(mktemp)"
  set +e
  run_agent "$SELECTED_AGENT" 2>&1 | while IFS= read -r line || [[ -n "$line" ]]; do
    printf '%s\n' "$line"
    printf '%s\n' "$line" >> "$CYCLE_OUTPUT"
  done
  STATUS=${PIPESTATUS[0]}
  set -e
  OUTPUT_BYTES="$(wc -c < "$CYCLE_OUTPUT" | tr -d '[:space:]')"
  rm -f "$CYCLE_OUTPUT"

  printf '[repeat] %s cycle=%d agent=%s exit=%d bytes=%s\n' "$(timestamp_utc)" "$CYCLE" "$SELECTED_AGENT" "$STATUS" "$OUTPUT_BYTES" >&2

  # A missing or non-executable harness binary cannot be fixed by retrying, so
  # abort the whole loop. resolve_bin reports those as exit 127.
  if [[ "$STATUS" -eq 127 ]]; then
    die "harness '$SELECTED_AGENT' binary unavailable; aborting"
  fi

  if [[ "$STATUS" -eq 124 ]]; then
    printf '[repeat] %s cycle=%d agent=%s WARN timed out after %ss; killed, continuing\n' "$(timestamp_utc)" "$CYCLE" "$SELECTED_AGENT" "$TIMEOUT_SECONDS" >&2
  elif [[ "$STATUS" -ne 0 ]]; then
    printf '[repeat] %s cycle=%d agent=%s WARN non-zero exit; continuing to next cycle\n' "$(timestamp_utc)" "$CYCLE" "$SELECTED_AGENT" >&2
  elif [[ "$OUTPUT_BYTES" -eq 0 ]]; then
    printf '[repeat] %s cycle=%d agent=%s WARN exit 0 but produced no output (likely quota/auth failure); continuing\n' "$(timestamp_utc)" "$CYCLE" "$SELECTED_AGENT" >&2
  fi

  if [[ -n "$TIMES_COUNT" && "$CYCLE" -ge "$TIMES_COUNT" ]]; then
    exit 0
  fi

  printf '[repeat] %s sleeping=%s before next cycle\n' "$(timestamp_utc)" "$WAIT_INTERVAL" >&2
  sleep "$WAIT_SECONDS"
done
