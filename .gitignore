# Rust build artifacts
/target/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Nix build output cache
.nix-output/

# Secrets
.env
*.pem
*.key
result
.claude/worktrees/

# Vendored debug sources
vendor/debug/

# Staged by scripts/build-image.sh — agent-cheatsheets
images/default/.cheatsheets/
# Staged by scripts/build-image.sh — cheatsheets-license-tiered (bundled-tier bake + meta side-channel)
# @trace spec:cheatsheets-license-tiered
images/default/.cheatsheet-sources/
images/default/.cheatsheets-meta/


# Pre-built tillandsias-router-sidecar (musl static-pie binary).
# Built by scripts/build-sidecar.sh; embedded into tray binary via
# include_bytes! in src-tauri/src/embedded.rs. Not source-controlled —
# rebuilds on every fresh clone.
# @trace spec:opencode-web-session-otp
images/router/tillandsias-router-sidecar

# Sidecar nested-cargo target dir (avoids workspace lock deadlock).
# @trace spec:opencode-web-session-otp
/target-musl/

# cheatsheet-sources: TOMBSTONED by cheatsheets-license-tiered (replaced by
# image-baked /opt/cheatsheet-sources/ + per-project pull cache). The whole
# directory is now gitignored to guard against any local cache pollution that
# the legacy fetcher might emit during the retention window.
# Keep cheatsheet-sources/.gitkeep-tombstone tracked (negation) so the
# tombstone marker survives the gitignore.
# @trace spec:cheatsheets-license-tiered, spec:cheatsheet-source-layer
cheatsheet-sources/
!cheatsheet-sources/.gitkeep-tombstone

# Local diagnostic capture artifacts produced by manual --diagnostics smoke
# runs (stdout/stderr redirects). Ephemeral debugging state — never source-
# controlled. Pattern matches diag.log, diag2.err, diag10.log, etc.
# @trace spec:runtime-diagnostics-stream
/diag*.log
/diag*.err
