{
  "identifier": "default",
  "description": "Default capabilities for the Tillandsias tray application",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "core:window:allow-create",
    "core:window:allow-set-focus",
    "core:window:allow-close",
    "shell:allow-open",
    "updater:default"
  ]
}
