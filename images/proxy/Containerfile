# @trace spec:proxy-container, spec:reverse-proxy-internal
# MITM caching HTTP/HTTPS forward proxy for Tillandsias enclave network.
# Built on Alpine + squid — minimal footprint (~15-20MB).
# DISTRO: Alpine 3.20 — busybox sh default, bash installed explicitly.
#         Health checks use wget (busybox built-in, NOT curl).
#         CA bundle at /etc/ssl/certs/ca-certificates.crt (NOT Fedora's /etc/pki/).
#         User creation: adduser -D (NOT useradd).
FROM docker.io/library/alpine:3.20

# @trace spec:proxy-container, spec:reverse-proxy-internal
# Squid + SSL for MITM proxy; squid + openssl for SSL bump support
# ca-certificates for upstream TLS verification
# bash: entrypoint.sh uses #!/bin/bash (busybox sh would also work but bash is explicit)
# Alpine's squid package includes SSL support (--enable-ssl-crtd) by default.
# No separate squid-openssl package exists on Alpine 3.20.
# DISTRO: apk add --no-cache (Alpine), NOT microdnf/dnf (Fedora)
# DISTRO: adduser -D (Alpine), NOT useradd (Fedora)
RUN apk add --no-cache squid openssl bash ca-certificates \
    && adduser -D -u 1000 -s /sbin/nologin proxy \
    && mkdir -p /var/spool/squid /var/log/squid /var/run/squid \
    && mkdir -p /var/lib/squid /etc/squid/certs \
    && chown -R proxy:proxy /var/spool/squid /var/log/squid /var/run/squid /var/lib/squid

COPY squid.conf /etc/squid/squid.conf
COPY allowlist.txt /etc/squid/allowlist.txt
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
# @trace spec:external-logs-layer
# Manifest of curated external log files published by this image.
# The tray-side auditor reads this at /etc/tillandsias/external-logs.yaml
# every 60 s and flags unlisted files in the role dir as LEAK events.
RUN mkdir -p /etc/tillandsias
COPY external-logs.yaml /etc/tillandsias/external-logs.yaml
RUN chmod +x /usr/local/bin/entrypoint.sh

USER proxy

EXPOSE 3128 3129

# @trace spec:proxy-container, spec:socket-container-orchestration
HEALTHCHECK --interval=2s --timeout=5s --start-period=5s --retries=15 \
    CMD nc -z 127.0.0.1 3128 || exit 1

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
