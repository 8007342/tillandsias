# @trace spec:git-mirror-service
# Lightweight git daemon for Tillandsias enclave network.
# Mirrors repositories from forge containers and optionally pushes to remotes.
# Built on Alpine — minimal footprint (~15MB).
# DISTRO: Alpine 3.20 — busybox sh default, bash installed explicitly.
#         Health checks use nc -z (busybox netcat, NOT /dev/tcp).
#         User creation: adduser -D (NOT useradd).
FROM docker.io/library/alpine:3.20

# @trace spec:git-mirror-service, spec:secret-management
# gh CLI is installed here (trusted container) — NOT in the forge (untrusted).
# GitHub credentials must never touch the forge environment.
# DISTRO: apk add --no-cache (Alpine), NOT microdnf/dnf (Fedora)
# DISTRO: adduser -D (Alpine), NOT useradd (Fedora)
RUN apk add --no-cache git git-daemon bash openssh-client github-cli \
    && adduser -D -u 1000 -s /bin/bash git \
    && mkdir -p /srv/git /var/log/git-service \
    && chown -R git:git /srv/git /var/log/git-service

COPY entrypoint.sh /usr/local/bin/entrypoint.sh
COPY post-receive-hook.sh /usr/local/share/git-service/post-receive-hook.sh
RUN chmod +x /usr/local/bin/entrypoint.sh /usr/local/share/git-service/post-receive-hook.sh

USER git

EXPOSE 9418

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
