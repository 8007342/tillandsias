# @trace spec:git-mirror-service, spec:user-runtime-lifecycle
# Lightweight git daemon for Tillandsias enclave network.
# Mirrors repositories from forge containers and optionally pushes to remotes.
# Built on Alpine 3.20 — minimal footprint (~15MB), busybox shell, explicit bash.
#
# Observability markers:
#   - HEALTHCHECK validates daemon readiness via port 9418
#   - Log aggregation via syslog (local1 facility) to host
#   - Secrets management: credentials from /run/secrets (ephemeral podman mounts)
#   - External log manifest at /etc/tillandsias/external-logs.yaml (audited by tray)
#
# DISTRO notes:
#   - apk add --no-cache (Alpine package manager)
#   - adduser -D (Alpine user creation, not useradd)
#   - nc from busybox (health check), not GNU netcat
#
# @trace spec:tillandsias-vault — use the same pinned upstream image as the
# Vault service and copy only the official binary needed for Agent auto-auth.
FROM docker.io/hashicorp/vault:1.18 AS vault-agent

FROM docker.io/library/alpine:3.20

# @trace spec:git-mirror-service, spec:secrets-management, spec:native-secrets-store
# Step 1: Install dependencies
#   - git, git-daemon: core VCS functionality
#   - bash: needed for entrypoint scripts (Alpine default is sh)
#   - openssh-client: for authentication to remote repositories
#   - github-cli (gh): for authenticated GitHub operations (TRUSTED container only)
#
# Step 2: Create unprivileged 'git' user (UID 1000, matches host --userns=keep-id)
#
# Step 3: Create working directories with proper ownership
#   - /srv/git: bare repository storage
#   - /var/log/git-service: structured logs (aggregated via syslog)
#   - /strategic: reserved for future state management
#
# Security: ALL operations run as unprivileged 'git' user
# @trace spec:tillandsias-vault — curl + jq are required by /usr/local/bin/vault-cli
# so the relay helper can fetch the GitHub token from Vault at push time.
RUN apk add --no-cache \
        git \
        git-daemon \
        bash \
        openssh-client \
        github-cli \
        curl \
        jq \
        ruby \
    && adduser -D -u 1000 -s /bin/bash git \
    && mkdir -p /srv/git /var/log/git-service /strategic \
    && chown -R git:git /srv/git /var/log/git-service /strategic

# @trace spec:tillandsias-vault, spec:git-mirror-service
# Vault Agent renews the git mirror's current 1h client token and performs a
# fresh AppRole login after max_ttl. The AppRole SecretID never enters argv or
# environment variables.
COPY --from=vault-agent /bin/vault /usr/local/bin/vault

# @trace spec:git-mirror-service, spec:user-runtime-lifecycle
# Copy entrypoint script (orchestration entry point)
COPY entrypoint.sh /usr/local/bin/entrypoint.sh

# @trace spec:git-mirror-service, spec:podman-orchestration
# Copy receive hooks and the synchronous upstream relay helper.
COPY post-receive-hook.sh /usr/local/share/git-service/post-receive-hook.sh
COPY pre-receive-hook.sh /usr/local/share/git-service/pre-receive-hook.sh
COPY relay-refs.sh /usr/local/share/git-service/relay-refs.sh

# @trace spec:git-mirror-service
# Unborn-HEAD repair helper (2026-07-20): a bare mirror's HEAD must always
# name a cloneable head; the entrypoint runs this at init/seed/fast-forward
# and offline fixtures exec the same file (ENSURE_HEAD override).
COPY ensure-mirror-head.sh /usr/local/share/git-service/ensure-mirror-head

# @trace spec:git-mirror-service
# Order 449: bounded-window exported-head reconcile pass — run periodically
# by the entrypoint so a host direct-push to origin cannot strand forge
# agents on a stale mirror between launches.
COPY reconcile-exported-heads.sh /usr/local/share/git-service/reconcile-exported-heads
RUN chmod +x /usr/local/share/git-service/ensure-mirror-head \
    /usr/local/share/git-service/reconcile-exported-heads

COPY vault-cli.sh /usr/local/bin/vault-cli.sh
RUN ln -s /usr/local/bin/vault-cli.sh /usr/local/bin/vault-cli

# @trace spec:tillandsias-vault, spec:git-mirror-service
COPY vault-agent.hcl /etc/tillandsias/vault-agent.hcl
COPY vault-agent-bootstrap.sh /usr/local/bin/vault-agent-bootstrap

# @trace spec:secrets-management — order 424: keeps the upstream token off argv.
COPY git-credential-tillandsias.sh /usr/local/bin/git-credential-tillandsias

# @trace spec:observability-convergence, spec:external-logs-layer
# Log manifest: lists all files this image writes to syslog/stdout.
# Tray auditor checks this every 60s; unlisted files trigger LEAK events.
# Enables zero-surprise logging for security/compliance audits.
RUN mkdir -p /etc/tillandsias
COPY external-logs.yaml /etc/tillandsias/external-logs.yaml

# @trace spec:user-runtime-lifecycle
# Make scripts executable (security: chmod only what's needed)
RUN chmod +x /usr/local/bin/entrypoint.sh \
              /usr/local/bin/vault-cli.sh \
              /usr/local/bin/vault-cli \
              /usr/local/bin/vault-agent-bootstrap \
              /usr/local/bin/git-credential-tillandsias \
              /usr/local/share/git-service/post-receive-hook.sh \
              /usr/local/share/git-service/pre-receive-hook.sh \
              /usr/local/share/git-service/relay-refs.sh

USER git

EXPOSE 9418

# @trace spec:git-mirror-service, spec:socket-container-orchestration
HEALTHCHECK --interval=2s --timeout=5s --start-period=3s --retries=10 \
    CMD nc -w 1 127.0.0.1 9418 </dev/null || exit 1

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
