# @trace spec:git-mirror-service
# Lightweight git daemon for Tillandsias enclave network.
# Mirrors repositories from forge containers and optionally pushes to remotes.
# Built on Alpine — minimal footprint (~15MB).
FROM docker.io/library/alpine:3.20

RUN apk add --no-cache git git-daemon bash openssh-client \
    && adduser -D -u 1000 -s /bin/bash git \
    && mkdir -p /srv/git /var/log/git-service \
    && chown -R git:git /srv/git /var/log/git-service

COPY entrypoint.sh /usr/local/bin/entrypoint.sh
COPY post-receive-hook.sh /usr/local/share/git-service/post-receive-hook.sh
RUN chmod +x /usr/local/bin/entrypoint.sh /usr/local/share/git-service/post-receive-hook.sh

USER git

EXPOSE 9418

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
