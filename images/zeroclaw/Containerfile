# Tillandsias ZeroClaw — Project-scoped orchestration container
# @trace spec:zeroclaw-orchestration, spec:default-image
ARG BASE_IMAGE=localhost/tillandsias-forge-base
FROM ${BASE_IMAGE}

RUN useradd -u 1000 -m -s /bin/bash forge

# ── Directory structure ────────────────────────────────────────
RUN mkdir -p /home/forge/src \
    && mkdir -p /home/forge/.cache/tillandsias \
    && mkdir -p /home/forge/.config/opencode/instructions \
    && mkdir -p /home/forge/.config-overlay/mcp \
    && mkdir -p /opt/skills

# ── ZeroClaw instructions overlay ────────────────────────────
# Only approved orchestration instructions — no forge tooling docs.
COPY config-overlay/opencode/instructions/ /home/forge/.config/opencode/instructions/

# ── OpenCode config (MCP server wiring, model, approved skills only) ─────
COPY config-overlay/opencode/config.json /home/forge/.config/opencode/config.json

# ── Host MCP bridge script ──────────────────────────────────────
COPY config-overlay/mcp/zeroclaw-host.sh /home/forge/.config-overlay/mcp/zeroclaw-host.sh
RUN chmod +x /home/forge/.config-overlay/mcp/zeroclaw-host.sh

# ── Skills mapping ─────────────────────────────────────────────
COPY skills/ /opt/skills/

# ── Entrypoint ─────────────────────────────────────────────────
COPY entrypoint.sh /usr/local/bin/entrypoint-zeroclaw.sh
RUN chmod +x /usr/local/bin/entrypoint-zeroclaw.sh

RUN chown -R 1000:1000 /home/forge /opt

USER 1000:1000
WORKDIR /home/forge/src
ENTRYPOINT ["/usr/local/bin/entrypoint-zeroclaw.sh"]
ENV HOME=/home/forge USER=forge
