# @trace spec:inference-container
# Local LLM inference server for Tillandsias enclave network.
# Runs ollama — models stay cached via volume mount.
# Built on Fedora Minimal to match the forge image.
# DISTRO: Fedora Minimal 44 — microdnf (NOT dnf), glibc, bash default.
#         Health checks use curl (installed explicitly, NOT wget).
#         User creation: useradd (NOT Alpine's adduser -D).
#         CA bundle at /etc/pki/tls/certs/ca-bundle.crt (NOT Alpine's /etc/ssl/).
FROM registry.fedoraproject.org/fedora-minimal:44

# @trace spec:inference-container
# Runtime deps for ollama, minimal deps for running ollama CPU-only
# pciutils provides lspci (runtime GPU detection in entrypoint)
# DISTRO: microdnf (Fedora Minimal), NOT apk (Alpine) or dnf (standard Fedora)
# DISTRO: wget intentionally omitted — curl is the HTTP tool here.
#         Rust health checks (handlers.rs) MUST use curl, not wget.
RUN microdnf install -y bash curl ca-certificates zstd tar gzip pciutils \
    && microdnf clean all

# @trace spec:inference-container
# -- Install ollama binary directly (CPU-only) --
# The official install script downloads ~2GB including GPU libraries
# (CUDA runners, ROCm, etc.) even on CPU-only systems. Instead, we
# download the release tarball and extract ONLY bin/ollama, skipping
# the lib/ollama/ directory which contains GPU runners (~1.8GB).
#
# GPU users: the entrypoint detects GPUs at runtime. GPU runner libs
# can be volume-mounted or pulled on demand if needed.
#
# The tarball extracts to: bin/ollama (~200MB) + lib/ollama/ (~1.8GB).
# We only need bin/ollama for CPU inference.
RUN curl -fsSL -o /tmp/ollama.tar.zst \
    "https://github.com/ollama/ollama/releases/latest/download/ollama-linux-amd64.tar.zst" \
    && mkdir -p /usr/local/bin \
    && zstd -d /tmp/ollama.tar.zst -o /tmp/ollama.tar \
    && tar -xf /tmp/ollama.tar -C /usr/local bin/ollama \
    && rm -f /tmp/ollama.tar.zst /tmp/ollama.tar \
    && test -x /usr/local/bin/ollama

# -- Create non-root user --
# DISTRO: useradd (Fedora shadow-utils), NOT adduser -D (Alpine)
RUN useradd -u 1000 -m -s /bin/bash ollama

# -- Model cache directory (volume-mountable) --
RUN mkdir -p /home/ollama/.ollama/models/ \
    && chown -R 1000:1000 /home/ollama

# ── Bake T0 + T1 tool-capable models into /opt/baked-models ─────
# @trace spec:inference-container, spec:zen-default-with-ollama-analysis-pool
# Pull at image build time (direct internet, no proxy) so we sidestep the
# Squid SSL-bump EOF that runtime ollama pulls keep hitting (memory:
# project_squid_ollama_eof.md). Stash under /opt/baked-models/ NOT under
# /home/ollama/.ollama/models/ — the latter is bind-mounted at runtime
# from ~/.cache/tillandsias/models, which would shadow the baked copy.
# The entrypoint rsyncs from /opt/baked-models/ into the runtime cache
# when manifests are missing. T0=qwen2.5:0.5b (~400MB), T1=llama3.2:3b
# (~2GB). Both follow tool-call schemas, unlike tinyllama.
RUN mkdir -p /opt/baked-models && chown -R 1000:1000 /opt/baked-models
USER 1000:1000
RUN OLLAMA_MODELS=/opt/baked-models \
        OLLAMA_HOST=127.0.0.1:11434 \
        /usr/local/bin/ollama serve & \
    OLLAMA_PID=$! ; \
    for i in $(seq 1 30); do \
        OLLAMA_HOST=127.0.0.1:11434 /usr/local/bin/ollama list >/dev/null 2>&1 && break ; \
        sleep 1 ; \
    done ; \
    OLLAMA_HOST=127.0.0.1:11434 OLLAMA_MODELS=/opt/baked-models \
        /usr/local/bin/ollama pull qwen2.5:0.5b && \
    OLLAMA_HOST=127.0.0.1:11434 OLLAMA_MODELS=/opt/baked-models \
        /usr/local/bin/ollama pull llama3.2:3b && \
    OLLAMA_HOST=127.0.0.1:11434 OLLAMA_MODELS=/opt/baked-models \
        /usr/local/bin/ollama list ; \
    kill "$OLLAMA_PID" 2>/dev/null ; wait "$OLLAMA_PID" 2>/dev/null ; true
USER root

# -- Entrypoint --
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
# @trace spec:external-logs-layer
# Manifest of curated external log files published by this image.
# The tray-side auditor reads this at /etc/tillandsias/external-logs.yaml
# every 60 s and flags unlisted files in the role dir as LEAK events.
RUN mkdir -p /etc/tillandsias
COPY external-logs.yaml /etc/tillandsias/external-logs.yaml
RUN chmod +x /usr/local/bin/entrypoint.sh

USER 1000:1000

EXPOSE 11434

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
ENV HOME=/home/ollama USER=ollama
