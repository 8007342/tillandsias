# @trace spec:inference-container
# Local LLM inference server for Tillandsias enclave network.
# Runs ollama — models stay cached via volume mount.
# Built on Fedora Minimal to match the forge image.
FROM registry.fedoraproject.org/fedora-minimal:43

# -- Deps for ollama install + GPU detection --
# pciutils provides lspci (GPU autodetection by ollama installer)
# @trace spec:inference-container
RUN microdnf install -y bash curl ca-certificates zstd tar gzip pciutils \
    && microdnf clean all

# -- Install ollama via official script --
# The installer uses lspci to detect NVIDIA/AMD GPUs and downloads
# the appropriate GPU libraries (CUDA/ROCm). At runtime, the host GPU
# is passed through via --device=/dev/nvidia0 etc.
# The || true is needed because the ollama installer tries to add the
# NVIDIA repo via `dnf5 config-manager` which is a plugin not present
# in fedora-minimal:43. The installer exits non-zero even though ollama
# itself installs successfully. We verify the binary exists afterward.
RUN curl -fsSL https://ollama.com/install.sh | sh || true
RUN test -x /usr/local/bin/ollama || { echo "ERROR: ollama binary not found after install"; exit 1; }

# -- Create non-root user --
RUN useradd -u 1000 -m -s /bin/bash ollama

# -- Model cache directory (volume-mountable) --
RUN mkdir -p /home/ollama/.ollama/models/ \
    && chown -R 1000:1000 /home/ollama

# -- Entrypoint --
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

USER 1000:1000

EXPOSE 11434

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
ENV HOME=/home/ollama USER=ollama
