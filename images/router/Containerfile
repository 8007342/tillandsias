# @trace spec:subdomain-routing-via-reverse-proxy, spec:fix-router-loopback-port
# Tillandsias router — Caddy 2 reverse proxy that maps
# `<service>.<project>.localhost` to enclave containers by name + port.
#
# Two access paths, both defended in depth:
#   1. Host loopback   — `-p 127.0.0.1:8080:8080` from the tray's podman
#                        invocation. Host kernel restricts the listener to
#                        127.0.0.1, so the LAN/internet can't reach it at
#                        the socket level.
#   2. Enclave network — alias `router` on the tillandsias-enclave bridge.
#                        Forge agents reach this through HTTP_PROXY=proxy:3128;
#                        Squid recognises `*.localhost` and forwards to
#                        router:8080 via cache_peer.
#
# Caddy ALSO enforces a `remote_ip` allowlist (127.0.0.1, ::1, RFC 1918
# private blocks) — anything else gets a 403 before any route matches.
# This is belt-and-suspenders on top of the binding-level loopback restriction.

FROM docker.io/library/caddy:2-alpine

# Runtime deps (curl for health probes from the tray, libcap for setcap).
RUN apk add --no-cache curl libcap

# @trace spec:fix-router-loopback-port
# CRITICAL: strip the cap_net_bind_service file capability from the
# Caddy binary. The upstream caddy:2-alpine image sets `cap_net_bind_service=ep`
# on /usr/bin/caddy so Caddy can bind port 80 even when the container's
# USER is non-root. But Tillandsias launches every container with
# `--security-opt=no-new-privileges` AND `--cap-drop=ALL` — under those
# flags the kernel rejects exec() of ANY binary whose file capabilities
# exceed the bounding set. Result: bash's `exec caddy` fails with EPERM
# and the router container dies on startup before binding any port.
#
# We don't NEED the capability anyway because the in-container listener
# moved to :8080 (an unprivileged port) per fix-router-loopback-port;
# the host publish is `127.0.0.1:8080:8080`. Stripping the file cap means
# Caddy runs as a fully unprivileged process, matching the rest of the
# enclave's defence-in-depth.
#
# Provenance: file capabilities + no_new_privs interaction documented at
# https://man7.org/linux/man-pages/man7/capabilities.7.html (search
# "no_new_privs"); upstream Caddy fcaps are set in
# https://github.com/caddyserver/caddy-docker/blob/master/2.10/alpine/Dockerfile
RUN setcap -r /usr/bin/caddy

# /run/router/ holds the dynamic Caddyfile written by the tray; create it
# at build time so the entrypoint can rely on the directory existing
# before any host bind-mount lands. Empty placeholder file means the
# initial merge produces just the base config.
RUN mkdir -p /run/router \
    && touch /run/router/dynamic.Caddyfile

# Static base config — enables admin API + gives a default 404 with the
# trusted-source allowlist baked in. The dynamic per-project routes are
# bind-mounted at /run/router/dynamic.Caddyfile and merged at startup.
COPY base.Caddyfile /etc/caddy/base.Caddyfile
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
COPY router-reload.sh /usr/local/bin/router-reload.sh
RUN chmod +x /usr/local/bin/entrypoint.sh /usr/local/bin/router-reload.sh

# @trace spec:fix-router-loopback-port
# Internal listener moved from :80 to :8080 — no privileged-port binding
# needed, so we can run with the upstream image's default USER without
# requiring capabilities or root inside the container.
EXPOSE 8080
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
