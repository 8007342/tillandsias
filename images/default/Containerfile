# Tillandsias Forge — Fedora Minimal
# Standard glibc, SELinux-ready, FHS-compliant.
# Pre-built binaries (OpenCode, Claude Code) execute directly — no linker hacks.
# @trace spec:default-image
# DISTRO: Fedora Minimal 43 — microdnf (NOT dnf), glibc, bash default.
#         Both curl AND wget installed explicitly.
#         User creation: useradd (NOT Alpine's adduser -D).
#         CA bundle at /etc/pki/tls/certs/ca-bundle.crt.
FROM registry.fedoraproject.org/fedora-minimal:43

# @trace spec:default-image — forge system packages
# ── System packages ────────────────────────────────────────────
# FULL-BATTERY forge: every compiler, interpreter, and build tool a coding
# agent typically reaches for, baked into the image at build time. The
# ephemeral contract says tools never get downloaded at runtime — the
# image IS the toolbox. The mutable overlay is ONLY for config files that
# need to be writable at runtime (opencode session db, openspec init
# output), NEVER for binaries.
#
# Layer grouping prioritises cache reuse: core utils rarely change, then
# shells, then compilers, then language runtimes (biggest), then CLI
# extras. Flutter gets its own layer because it's the heaviest single
# component (~1GB).
#
# DISTRO: microdnf (Fedora Minimal), NOT apk (Alpine) or dnf (standard
# Fedora). Some packages only exist under `dnf install --allowerasing`
# — where the need arises we call microdnf with the matching flag.
RUN microdnf install -y \
        bash coreutils findutils grep sed gawk tar gzip xz unzip zip bzip2 zstd \
        procps-ng shadow-utils ca-certificates which file less tree \
        fish zsh \
        git git-lfs gh curl wget jq ripgrep fd-find fzf \
        vim nano man-db \
        # Build essentials — compile anything C/C++/Rust/Go/FFI-bound
        gcc gcc-c++ clang lld llvm make cmake ninja-build \
        autoconf automake libtool pkgconf pkgconf-pkg-config patch \
        gdb strace ltrace binutils \
        # Python ecosystem
        python3 python3-pip python3-devel python3-virtualenv pipx \
        # Node ecosystem (yarn + pnpm added below via corepack)
        nodejs npm \
        # Java ecosystem
        java-21-openjdk-devel maven \
        # Go
        golang \
        # Rust toolchain from Fedora (rustup alternative is in /opt below)
        rust cargo rust-std-static \
        # Database clients (agents often need these)
        sqlite postgresql \
        # Networking / SSH clients
        openssh-clients rsync iputils iproute bind-utils \
        # Shell / fuzzy niceties the agent uses constantly
        bash-completion socat netcat openssl \
        # @trace spec:agent-cheatsheets, spec:default-image
        # Shell-script lint + formatter (cited from cheatsheets/utils/shellcheck-shfmt.md
        # as "added by agent-source-of-truth"). Both available from Fedora's repos.
        # protobuf-compiler ships the `protoc` binary cheatsheets/web/protobuf.md depends on.
        ShellCheck shfmt protobuf-compiler protobuf-devel xmlstarlet libxml2 \
    && microdnf clean all

# ── Node yarn + pnpm via npm -g ────────────────────────────────
# @trace spec:default-image
# Fedora's nodejs ships without corepack (they strip experimental features),
# so we install yarn + pnpm directly via npm. The npm prefix /usr lands the
# binaries in /usr/bin which is on PATH for every shell.
RUN npm install -g --prefix=/usr yarn pnpm \
    && yarn --version \
    && pnpm --version

# ── Python dev extras (pinned reasonable versions) ─────────────
# @trace spec:default-image
# `pipx` for tools the agent may invoke directly (ruff, black, mypy,
# pytest). Installed globally under /usr/local/pipx so they're on PATH
# from every forge user without per-project pip installs.
ENV PIPX_HOME=/opt/pipx \
    PIPX_BIN_DIR=/usr/local/bin \
    PATH=/usr/local/bin:$PATH
RUN mkdir -p "$PIPX_HOME" \
    && pipx install --global ruff \
    && pipx install --global black \
    && pipx install --global mypy \
    && pipx install --global pytest \
    && pipx install --global httpie \
    && pipx install --global uv \
    && pipx install --global poetry

# ── Gradle (installed from upstream — Fedora's gradle is often old) ─
# @trace spec:default-image
ENV GRADLE_VERSION=8.10 \
    GRADLE_HOME=/opt/gradle
RUN curl -fsSL "https://services.gradle.org/distributions/gradle-${GRADLE_VERSION}-bin.zip" \
        -o /tmp/gradle.zip \
    && unzip -q /tmp/gradle.zip -d /opt \
    && mv "/opt/gradle-${GRADLE_VERSION}" "$GRADLE_HOME" \
    && rm /tmp/gradle.zip \
    && ln -s "$GRADLE_HOME/bin/gradle" /usr/local/bin/gradle

# ── yq (mikefarah, Go-based) and grpcurl ─────────────────────────
# @trace spec:agent-cheatsheets, spec:default-image
# Both are needed by cheatsheets/utils/yq.md and cheatsheets/web/grpc.md.
# Neither has a Fedora package (kislyuk/yq is in EPEL but is a different,
# Python-based tool — not what mikefarah/yq cheatsheet describes), so we
# fetch upstream binaries pinned by version. Single layer for cache stability.
ENV YQ_VERSION=4.45.1 \
    GRPCURL_VERSION=1.9.1
RUN curl -fsSL "https://github.com/mikefarah/yq/releases/download/v${YQ_VERSION}/yq_linux_amd64" \
        -o /usr/local/bin/yq \
    && chmod +x /usr/local/bin/yq \
    && /usr/local/bin/yq --version \
    && curl -fsSL "https://github.com/fullstorydev/grpcurl/releases/download/v${GRPCURL_VERSION}/grpcurl_${GRPCURL_VERSION}_linux_x86_64.tar.gz" \
        -o /tmp/grpcurl.tar.gz \
    && tar -xzf /tmp/grpcurl.tar.gz --no-same-owner -C /usr/local/bin grpcurl \
    && chmod +x /usr/local/bin/grpcurl \
    && rm /tmp/grpcurl.tar.gz \
    && /usr/local/bin/grpcurl -version 2>&1 | head -1

# ── Flutter SDK (hard-installed at /opt/flutter, pre-cached) ───
# @trace spec:default-image
# Flutter is a heavyweight SDK (~1GB after precache) so it gets its own
# layer for cache stability. Pinned to a stable release. `flutter precache
# --linux` downloads Linux-desktop engine artefacts at image-build time so
# the forge never touches the network to bootstrap Flutter.
# Mobile (Android / iOS) tooling is NOT included — that requires Android
# Studio SDK and platform-specific licenses; Flutter web + desktop work
# without it.
ENV FLUTTER_VERSION=3.24.5 \
    FLUTTER_HOME=/opt/flutter \
    PATH=/opt/flutter/bin:$PATH \
    PUB_CACHE=/opt/flutter/.pub-cache
RUN curl -fsSL "https://storage.googleapis.com/flutter_infra_release/releases/stable/linux/flutter_linux_${FLUTTER_VERSION}-stable.tar.xz" \
        -o /tmp/flutter.tar.xz \
    && tar -xJf /tmp/flutter.tar.xz -C /opt \
    && rm /tmp/flutter.tar.xz \
    && git config --system --add safe.directory "$FLUTTER_HOME" \
    && "$FLUTTER_HOME/bin/flutter" --no-version-check config --no-analytics \
    && "$FLUTTER_HOME/bin/flutter" --no-version-check precache --linux --web --no-android --no-ios --no-macos --no-windows \
    && chmod -R a+rX "$FLUTTER_HOME"

# ── Coding agents (hard-installed, NOT mutable overlay) ─────────
# @trace spec:default-image, spec:tools-overlay-deprecated
# OpenCode + Claude Code + OpenSpec used to live in the mutable
# `.tools-overlay` image built at runtime against the proxy. That violated
# the ephemeral contract: a downloaded binary in the user-writable layer is
# state, not config. We move them into /opt at image-build time so:
#   • forge containers boot with the agents already on PATH
#   • the mutable overlay is reduced to genuine config (openspec init,
#     opencode session db) which legitimately needs to be writable
#   • image rebuilds are deterministic — same VERSION = same agent bins
RUN mkdir -p /opt/agents/claude /opt/agents/openspec /opt/agents/opencode/bin \
    && npm install -g --prefix=/opt/agents/claude @anthropic-ai/claude-code \
    && npm install -g --prefix=/opt/agents/openspec @fission-ai/openspec \
    && ln -s /opt/agents/claude/bin/claude /usr/local/bin/claude \
    && ln -s /opt/agents/openspec/bin/openspec /usr/local/bin/openspec \
    && curl -fsSL https://opencode.ai/install \
        | OPENCODE_INSTALL_DIR=/opt/agents/opencode bash \
    && if [ ! -x /opt/agents/opencode/bin/opencode ] && [ -x /root/.opencode/bin/opencode ]; then \
           cp /root/.opencode/bin/opencode /opt/agents/opencode/bin/opencode; \
       fi \
    && rm -rf /root/.opencode \
    && ln -s /opt/agents/opencode/bin/opencode /usr/local/bin/opencode \
    && /usr/local/bin/claude --version \
    && /usr/local/bin/openspec --version \
    && /usr/local/bin/opencode --version

# ── Create forge user ──────────────────────────────────────────
# DISTRO: useradd (Fedora shadow-utils), NOT adduser -D (Alpine)
RUN useradd -u 1000 -m -s /bin/bash forge

# ── Directory structure ────────────────────────────────────────
RUN mkdir -p /home/forge/src \
    && mkdir -p /home/forge/.cache/tillandsias \
    && mkdir -p /home/forge/.config/opencode \
    && mkdir -p /tmp && chmod 1777 /tmp

# ── Shared library ─────────────────────────────────────────────
RUN mkdir -p /usr/local/lib/tillandsias
COPY lib-common.sh /usr/local/lib/tillandsias/lib-common.sh

# ── Entrypoints ────────────────────────────────────────────────
COPY entrypoint.sh /usr/local/bin/tillandsias-entrypoint.sh
COPY entrypoint-forge-opencode.sh /usr/local/bin/entrypoint-forge-opencode.sh
COPY entrypoint-forge-opencode-web.sh /usr/local/bin/entrypoint-forge-opencode-web.sh
COPY entrypoint-forge-claude.sh /usr/local/bin/entrypoint-forge-claude.sh
COPY entrypoint-terminal.sh /usr/local/bin/entrypoint-terminal.sh
# @trace spec:opencode-web-session
# Tiny Node.js HTTP proxy that injects SSE keepalive comments so Bun's default
# 10s idleTimeout doesn't drop /event and /global/event streams when the
# session is idle. Fronts opencode serve on port 4096 → 4097.
COPY sse-keepalive-proxy.js /usr/local/bin/sse-keepalive-proxy.js
RUN chmod +x /usr/local/bin/tillandsias-entrypoint.sh \
             /usr/local/bin/entrypoint-forge-opencode.sh \
             /usr/local/bin/entrypoint-forge-opencode-web.sh \
             /usr/local/bin/entrypoint-forge-claude.sh \
             /usr/local/bin/entrypoint-terminal.sh \
             /usr/local/bin/sse-keepalive-proxy.js

# No GIT_ASKPASS helper in the forge image — forge containers have ZERO
# credentials. The old askpass was a dead-code vector superseded by the
# native-secrets-store model: only the git-service container receives the
# ephemeral token, and the forge pushes/pulls via the enclave-internal
# git:// mirror which requires no auth.
# @trace spec:secrets-management, spec:forge-offline, spec:native-secrets-store

# ── OpenCode config ────────────────────────────────────────────
COPY opencode.json /home/forge/.config/opencode/config.json
# @trace spec:opencode-web-session, spec:default-image
# Default UI theme (tokyonight) — applies to both `opencode` TUI and
# `opencode serve` web UI. Overrideable per-project by mounting a different
# tui.json into ~/.config/opencode/ (project workspace bind takes precedence
# at the user-config layer when applications resolve XDG paths).
COPY config-overlay/opencode/tui.json /home/forge/.config/opencode/tui.json

# ── Shell configs ──────────────────────────────────────────────
RUN mkdir -p /etc/skel/.config/fish
COPY shell/bashrc /etc/skel/.bashrc
COPY shell/zshrc /etc/skel/.zshrc
COPY shell/config.fish /etc/skel/.config/fish/config.fish
RUN mkdir -p /home/forge/.config/fish/conf.d
COPY shell/config.fish /home/forge/.config/fish/conf.d/tillandsias.fish

# ── Welcome script ─────────────────────────────────────────────
RUN mkdir -p /usr/local/share/tillandsias
COPY forge-welcome.sh /usr/local/share/tillandsias/forge-welcome.sh
RUN chmod +x /usr/local/share/tillandsias/forge-welcome.sh || true

# ── Locale files ───────────────────────────────────────────────
# @trace spec:environment-runtime
RUN mkdir -p /etc/tillandsias/locales
COPY locales/ /etc/tillandsias/locales/

# ── Agent cheatsheets ─────────────────────────────────────────
# @trace spec:agent-cheatsheets, spec:default-image
# `cheatsheets/` lives at the project root as the source of truth.
# `scripts/build-image.sh` stages it into `images/default/.cheatsheets/`
# right before podman build, so the COPY here resolves inside the build
# context. The staged dir is removed after build completes.
#
# Owned root:root, world-readable, NOT writable by forge user — cheatsheets
# are image-state. To suggest changes, agents write a
# RUNTIME_LIMITATIONS_NNN.md in the project workspace (see
# /opt/cheatsheets/runtime/runtime-limitations.md).
RUN mkdir -p /opt/cheatsheets
COPY .cheatsheets/ /opt/cheatsheets/
RUN chmod -R a+rX /opt/cheatsheets && chmod -R go-w /opt/cheatsheets

# ── Fix ownership ──────────────────────────────────────────────
RUN chown -R 1000:1000 /home/forge

USER 1000:1000
WORKDIR /home/forge/src
ENTRYPOINT ["/usr/local/bin/entrypoint-forge-claude.sh"]
# No EXPOSE — forge containers live on the enclave network only.
# @trace spec:forge-offline, spec:enclave-network
ENV HOME=/home/forge USER=forge \
    TILLANDSIAS_CHEATSHEETS=/opt/cheatsheets
