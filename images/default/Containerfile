# Tillandsias Forge — User Runtime Image
# @trace spec:default-image
# Builds upon the heavy base image to inject configuration,
# skills, and entrypoints. Rapidly rebuildable.
ARG BASE_IMAGE=localhost/tillandsias-forge-base
FROM ${BASE_IMAGE}

# ── Environment exports for diagnostics and agent discovery ─────
ENV TILLANDSIAS_CHEATSHEETS=/opt/cheatsheets \
    DART_ROOT=/opt/dart-sdk \
    FLUTTER_ROOT=/opt/flutter

# ── Create forge user ──────────────────────────────────────────
# DISTRO: useradd (Fedora shadow-utils), NOT adduser -D (Alpine)
RUN useradd -u 1000 -m -s /bin/bash forge

# ── Directory structure ────────────────────────────────────────
# /home/linuxbrew: Homebrew-on-Linux STANDARD prefix, pre-created and
# forge-owned so the runtime lazy install (lib-common ensure_brew, order
# 294) can clone into it rootless. Bottles are only prebuilt for this
# exact prefix — any other prefix forces source builds. Empty at CREATION
# (no network at image build); populated on first use.
RUN mkdir -p /home/forge/src \
    && mkdir -p /home/forge/.cache/tillandsias \
    && mkdir -p /home/forge/.config/opencode \
    && mkdir -p /home/linuxbrew && chown forge:forge /home/linuxbrew \
    && mkdir -p /opt/cheatsheets /opt/cheatsheets-image /opt/cheatsheet-sources \
    && mkdir -p /tmp && chmod 1777 /tmp

# ── Cheatsheets ────────────────────────────────────────────────
COPY cheatsheets/ /opt/cheatsheets-image/
COPY cheatsheet-sources/ /opt/cheatsheet-sources/

# ── Shared library ─────────────────────────────────────────────
RUN mkdir -p /usr/local/lib/tillandsias
COPY lib-common.sh /usr/local/lib/tillandsias/lib-common.sh
COPY brew-tools-allowlist.txt /usr/local/lib/tillandsias/brew-tools-allowlist.txt
COPY brew-shim-exec.sh /usr/local/bin/tillandsias-brew-shim-exec
COPY vault-cli.sh /usr/local/bin/vault-cli.sh
COPY codex-device-auth.sh /usr/local/bin/codex-device-auth
# @trace spec:error-message-localization
COPY lib-localized-errors.sh /usr/local/lib/tillandsias/lib-localized-errors.sh

# ── Entrypoints ────────────────────────────────────────────────
COPY entrypoint.sh /usr/local/bin/tillandsias-entrypoint.sh
COPY entrypoint-forge-opencode.sh /usr/local/bin/entrypoint-forge-opencode.sh
COPY entrypoint-forge-opencode-web.sh /usr/local/bin/entrypoint-forge-opencode-web.sh
COPY entrypoint-forge-claude.sh /usr/local/bin/entrypoint-forge-claude.sh
COPY entrypoint-forge-codex.sh /usr/local/bin/entrypoint-forge-codex.sh
COPY entrypoint-forge-antigravity.sh /usr/local/bin/entrypoint-forge-antigravity.sh
COPY entrypoint-terminal.sh /usr/local/bin/entrypoint-terminal.sh
COPY sse-keepalive-proxy.js /usr/local/bin/sse-keepalive-proxy.js
RUN chmod +x /usr/local/bin/tillandsias-entrypoint.sh \
             /usr/local/bin/entrypoint-forge-opencode.sh \
             /usr/local/bin/entrypoint-forge-opencode-web.sh \
             /usr/local/bin/entrypoint-forge-claude.sh \
             /usr/local/bin/entrypoint-forge-codex.sh \
             /usr/local/bin/entrypoint-forge-antigravity.sh \
             /usr/local/bin/entrypoint-terminal.sh \
             /usr/local/bin/tillandsias-brew-shim-exec \
             /usr/local/bin/vault-cli.sh \
             /usr/local/bin/codex-device-auth \
             /usr/local/bin/sse-keepalive-proxy.js

# ── Locale ──────────────────────────────────────────────────────
# @trace spec:forge-git-ergonomics
ENV LANG=en_US.UTF-8

# No GIT_ASKPASS helper in the forge image — forge containers have ZERO
# credentials. The old askpass was a dead-code vector superseded by the
# native-secrets-store model: only the git-service container receives the
# ephemeral token, and the forge pushes/pulls via the enclave-internal
# git:// mirror which requires no auth.
# @trace spec:secrets-management, spec:forge-offline, spec:native-secrets-store

# ── OpenCode config ────────────────────────────────────────────
COPY opencode.json /home/forge/.config/opencode/config.json
# @trace spec:browser-isolation-tray-integration, spec:opencode-web-session-otp, spec:default-image
# Default UI theme (tokyonight) — applies to both `opencode` TUI and
# `opencode serve` web UI. Overrideable per-project by mounting a different
# tui.json into ~/.config/opencode/ (project workspace bind takes precedence
# at the user-config layer when applications resolve XDG paths).
COPY config-overlay/opencode/tui.json /home/forge/.config/opencode/tui.json
COPY config-overlay/opencode/instructions/ /home/forge/.config/opencode/instructions/

# ── Shell configs ──────────────────────────────────────────────
RUN mkdir -p /etc/skel/.config/fish
COPY shell/bashrc /etc/skel/.bashrc
COPY shell/zshrc /etc/skel/.zshrc
COPY shell/config.fish /etc/skel/.config/fish/config.fish
RUN mkdir -p /home/forge/.config/fish/conf.d
COPY shell/config.fish /home/forge/.config/fish/conf.d/tillandsias.fish

# ── Welcome script ─────────────────────────────────────────────
RUN mkdir -p /usr/local/share/tillandsias
COPY forge-welcome.sh /usr/local/share/tillandsias/forge-welcome.sh
RUN chmod +x /usr/local/share/tillandsias/forge-welcome.sh || true

# ── Help system (locale-aware) ─────────────────────────────────
# @trace spec:help-system-localization
COPY help.sh /usr/local/share/tillandsias/help.sh
RUN chmod +x /usr/local/share/tillandsias/help*.sh || true
RUN ln -sf /usr/local/share/tillandsias/help.sh /usr/local/bin/tillandsias-help

# ── Shell helper functions ─────────────────────────────────────
# @trace spec:forge-shell-tools, spec:forge-environment-discoverability
RUN mkdir -p /etc/tillandsias
COPY config-overlay/shell-helpers.sh /etc/tillandsias/shell-helpers.sh
COPY config-overlay/shell-helpers.fish /etc/tillandsias/shell-helpers.fish
RUN chmod +x /etc/tillandsias/shell-helpers.sh || true

# ── Discovery CLIs ─────────────────────────────────────────────
# @trace spec:forge-environment-discoverability
# Restored from a74a13ec (feat(forge): discoverability CLIs). The
# COPY+symlink block was silently dropped in a later refactor while
# the bash scripts under cli/ stayed put.
RUN mkdir -p /opt/agents/tillandsias-cli/bin
COPY cli/tillandsias-inventory /opt/agents/tillandsias-cli/bin/tillandsias-inventory
COPY cli/tillandsias-services /opt/agents/tillandsias-cli/bin/tillandsias-services
COPY cli/tillandsias-models /opt/agents/tillandsias-cli/bin/tillandsias-models
COPY cli/tellme /opt/agents/tillandsias-cli/bin/tellme
RUN chmod +x /opt/agents/tillandsias-cli/bin/* \
    && ln -sf /opt/agents/tillandsias-cli/bin/tillandsias-inventory /usr/local/bin/tillandsias-inventory \
    && ln -sf /opt/agents/tillandsias-cli/bin/tillandsias-services /usr/local/bin/tillandsias-services \
    && ln -sf /opt/agents/tillandsias-cli/bin/tillandsias-models /usr/local/bin/tillandsias-models \
    && ln -sf /opt/agents/tillandsias-cli/bin/tellme /usr/local/bin/tellme

# ── Skills mapping ─────────────────────────────────────────────
# @trace spec:forge-skills-mapping
# Copy all AI skills so agents running inside the forge have immediate access.
RUN mkdir -p /opt/skills
COPY skills/ /opt/skills/

# ── Locale files ───────────────────────────────────────────────
# @trace spec:environment-runtime
RUN mkdir -p /etc/tillandsias/locales
COPY locales/ /etc/tillandsias/locales/

# ── Fix ownership ──────────────────────────────────────────────
RUN chown -R 1000:1000 /home/forge /opt

USER 1000:1000
WORKDIR /home/forge/src
# @trace spec:default-image, spec:forge-standalone
# Default steady-state attach path launches the Claude-oriented agent entrypoint.
# The standalone troubleshooting shell overrides this with `--entrypoint /bin/bash`
# so operators can inspect the forge image layers without starting the agent.
ENTRYPOINT ["/usr/local/bin/entrypoint-forge-claude.sh"]
# No EXPOSE — forge containers live on the enclave network only.
# @trace spec:forge-offline, spec:enclave-network
ENV HOME=/home/forge USER=forge
