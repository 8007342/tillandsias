# Tillandsias Forge — Fedora Minimal
# Standard glibc, SELinux-ready, FHS-compliant.
# Pre-built binaries (OpenCode, Claude Code) execute directly — no linker hacks.
# @trace spec:default-image
# DISTRO: Fedora Minimal 44 — microdnf (NOT dnf), glibc, bash default.
#         Both curl AND wget installed explicitly.
#         User creation: useradd (NOT Alpine's adduser -D).
#         CA bundle at /etc/pki/tls/certs/ca-bundle.crt.
FROM registry.fedoraproject.org/fedora-minimal:44

# @trace spec:default-image
# ── System packages ────────────────────────────────────────────
# LEAN forge: essential dev tools only. Terminal UX tools (mc, vim, nano,
# eza, bat, fd-find, fzf, htop, tree, zoxide) removed to save ~90MB.
# Users who need them can install via the tools overlay or microdnf.
# DISTRO: microdnf (Fedora Minimal), NOT apk (Alpine) or dnf (standard Fedora)
RUN microdnf install -y \
        bash coreutils findutils grep sed gawk tar gzip xz \
        procps-ng shadow-utils ca-certificates \
        fish zsh \
        git gh curl wget jq ripgrep \
        nodejs npm \
    && microdnf clean all

# ── Create forge user ──────────────────────────────────────────
# DISTRO: useradd (Fedora shadow-utils), NOT adduser -D (Alpine)
RUN useradd -u 1000 -m -s /bin/bash forge

# ── Directory structure ────────────────────────────────────────
RUN mkdir -p /home/forge/src \
    && mkdir -p /home/forge/.cache/tillandsias \
    && mkdir -p /home/forge/.config/opencode \
    && mkdir -p /tmp && chmod 1777 /tmp

# ── Shared library ─────────────────────────────────────────────
RUN mkdir -p /usr/local/lib/tillandsias
COPY lib-common.sh /usr/local/lib/tillandsias/lib-common.sh

# ── Entrypoints ────────────────────────────────────────────────
COPY entrypoint.sh /usr/local/bin/tillandsias-entrypoint.sh
COPY entrypoint-forge-opencode.sh /usr/local/bin/entrypoint-forge-opencode.sh
COPY entrypoint-forge-opencode-web.sh /usr/local/bin/entrypoint-forge-opencode-web.sh
COPY entrypoint-forge-claude.sh /usr/local/bin/entrypoint-forge-claude.sh
COPY entrypoint-terminal.sh /usr/local/bin/entrypoint-terminal.sh
RUN chmod +x /usr/local/bin/tillandsias-entrypoint.sh \
             /usr/local/bin/entrypoint-forge-opencode.sh \
             /usr/local/bin/entrypoint-forge-opencode-web.sh \
             /usr/local/bin/entrypoint-forge-claude.sh \
             /usr/local/bin/entrypoint-terminal.sh

# No GIT_ASKPASS helper in the forge image — forge containers have ZERO
# credentials. The old askpass was a dead-code vector superseded by the
# native-secrets-store model: only the git-service container receives the
# ephemeral token, and the forge pushes/pulls via the enclave-internal
# git:// mirror which requires no auth.
# @trace spec:secrets-management, spec:forge-offline, spec:native-secrets-store

# ── OpenCode config ────────────────────────────────────────────
COPY opencode.json /home/forge/.config/opencode/config.json
# @trace spec:opencode-web-session, spec:default-image
# Default UI theme (tokyonight) — applies to both `opencode` TUI and
# `opencode serve` web UI. Overrideable per-project by mounting a different
# tui.json into ~/.config/opencode/ (project workspace bind takes precedence
# at the user-config layer when applications resolve XDG paths).
COPY config-overlay/opencode/tui.json /home/forge/.config/opencode/tui.json

# ── Shell configs ──────────────────────────────────────────────
RUN mkdir -p /etc/skel/.config/fish
COPY shell/bashrc /etc/skel/.bashrc
COPY shell/zshrc /etc/skel/.zshrc
COPY shell/config.fish /etc/skel/.config/fish/config.fish
RUN mkdir -p /home/forge/.config/fish/conf.d
COPY shell/config.fish /home/forge/.config/fish/conf.d/tillandsias.fish

# ── Welcome script ─────────────────────────────────────────────
RUN mkdir -p /usr/local/share/tillandsias
COPY forge-welcome.sh /usr/local/share/tillandsias/forge-welcome.sh
RUN chmod +x /usr/local/share/tillandsias/forge-welcome.sh || true

# ── Locale files ───────────────────────────────────────────────
# @trace spec:environment-runtime
RUN mkdir -p /etc/tillandsias/locales
COPY locales/ /etc/tillandsias/locales/

# ── Fix ownership ──────────────────────────────────────────────
RUN chown -R 1000:1000 /home/forge

USER 1000:1000
WORKDIR /home/forge/src
ENTRYPOINT ["/usr/local/bin/entrypoint-forge-claude.sh"]
# No EXPOSE — forge containers live on the enclave network only.
# @trace spec:forge-offline, spec:enclave-network
ENV HOME=/home/forge USER=forge
