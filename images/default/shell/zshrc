# ~/.zshrc — tillandsias forge

# ── Permissions ───────────────────────────────────────────────
# Ensure files created in interactive sessions (and by tools we invoke)
# are user-writable on the host bind mount.
umask 0022

# ── PATH ─────────────────────────────────────────────────────
export PATH="$HOME/.cache/tillandsias/claude/bin:$HOME/.cache/tillandsias/openspec/bin:$HOME/.local/bin:$PATH"

# ── Package manager cache (persists via bind mount) ─────────
# @trace spec:forge-shell-tools
export NPM_CONFIG_PREFIX="$HOME/.cache/tillandsias/npm-global"
export CARGO_HOME="$HOME/.cache/tillandsias/cargo"
export GOPATH="$HOME/.cache/tillandsias/go"
export PIP_USER=1
export PYTHONUSERBASE="$HOME/.cache/tillandsias/pip"
export PATH="$NPM_CONFIG_PREFIX/bin:$CARGO_HOME/bin:$GOPATH/bin:$PYTHONUSERBASE/bin:$PATH"

# ── Completion ───────────────────────────────────────────────
autoload -Uz compinit && compinit

# ── History ──────────────────────────────────────────────────
HISTSIZE=10000
SAVEHIST=10000
HISTFILE=~/.zsh_history

# ── Prompt ───────────────────────────────────────────────────
PROMPT='%F{green}%~%f $ '

# ── Aliases ──────────────────────────────────────────────────
alias ll='eza -la'
alias la='eza -a'
alias ..='cd ..'
alias grep='grep --color=auto'

# ── bat as pager ─────────────────────────────────────────────
if (( $+commands[bat] )); then
    export MANPAGER="sh -c 'col -bx | bat -l man -p'"
fi

# ── fzf key bindings ────────────────────────────────────────
if (( $+commands[fzf] )); then
    eval "$(fzf --zsh 2>/dev/null)" || true
fi

# ── zoxide (smart cd) ───────────────────────────────────────
if (( $+commands[zoxide] )); then
    eval "$(zoxide init zsh)"
fi

# ── Welcome banner (mirrors fish + bash; idempotent across re-execs) ─
# @trace spec:default-image, spec:forge-environment-discoverability
if [[ -z "${TILLANDSIAS_WELCOME_SHOWN:-}" \
        && -f /usr/local/share/tillandsias/forge-welcome.sh ]]; then
    export TILLANDSIAS_WELCOME_SHOWN=1
    bash /usr/local/share/tillandsias/forge-welcome.sh
fi
