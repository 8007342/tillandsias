{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "default_agent": "build",
  "permission": "allow",
  "model": "opencode/big-pickle",
  "small_model": "opencode/gpt-5-nano",
  "instructions": [
    "/home/forge/.config-overlay/opencode/instructions/methodology.md",
    "/home/forge/.config-overlay/opencode/instructions/forge-discovery.md",
    "/home/forge/.config-overlay/opencode/instructions/cache-discipline.md",
    "/home/forge/.config-overlay/opencode/instructions/nix-first.md",
    "/home/forge/.config-overlay/opencode/instructions/openspec-workflow.md",
    "/home/forge/.config-overlay/opencode/instructions/flutter.md",
    "/home/forge/.config-overlay/opencode/instructions/model-routing.md",
    "/home/forge/.config-overlay/opencode/instructions/web-services.md"
  ],
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://inference:11434/v1"
      },
      "models": {
        "qwen2.5:0.5b": { "name": "Qwen 2.5 0.5B (local)" },
        "qwen2.5:7b": { "name": "Qwen 2.5 7B (local)" },
        "qwen2.5:14b": { "name": "Qwen 2.5 14B (local)" },
        "qwen2.5-coder:7b": { "name": "Qwen 2.5 Coder 7B (local)" },
        "qwen2.5-coder:14b": { "name": "Qwen 2.5 Coder 14B (local)" },
        "qwen2.5-coder:32b": { "name": "Qwen 2.5 Coder 32B (local)" },
        "llama3.2:1b": { "name": "LLaMA 3.2 1B (local)" },
        "llama3.2:3b": { "name": "LLaMA 3.2 3B (local)" },
        "llama3.1:8b": { "name": "LLaMA 3.1 8B (local)" },
        "gpt-oss:20b": { "name": "GPT-OSS 20B (local)" }
      }
    }
  },
  "mcp": {
    "git-tools": {
      "type": "local",
      "command": ["/home/forge/.config-overlay/mcp/git-tools.sh"],
      "enabled": true
    },
    "project-info": {
      "type": "local",
      "command": ["/home/forge/.config-overlay/mcp/project-info.sh"],
      "enabled": true
    }
  }
}
