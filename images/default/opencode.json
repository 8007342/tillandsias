{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "opencode": {
      "name": "OpenCode",
      "models": {
        "big-pickle": {
          "name": "big-pickle",
          "contextWindow": 100000,
          "maxOutput": 65536
        }
      }
    }
  },
  "model": "opencode/big-pickle",
  "tools": {
    "read": true,
    "edit": true,
    "write": true,
    "bash": true,
    "search": true,
    "glob": true,
    "git": true,
    "grep": true,
    "diff": true
  },
  "permissions": {
    "edit": "allow",
    "bash": "allow"
  }
}
