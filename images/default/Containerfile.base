# Tillandsias Forge — Fedora Minimal Base
# Heavy dependencies cached to improve rapid rebuilds of the final image.
# @trace spec:default-image
# Developer UX tools: fzf, eza, htop, mc, tree, nano, vim-minimal for interactive use.
FROM registry.fedoraproject.org/fedora-minimal:44

# ── System packages ────────────────────────────────────────────
RUN microdnf install -y --setopt=install_weak_deps=0 \
        bash coreutils findutils grep sed gawk tar gzip xz \
        procps-ng shadow-utils ca-certificates ncurses ncurses-term \
        fish zsh \
        git gh curl wget jq ripgrep fd-find bat fzf eza htop mc tree nano vim-minimal zoxide git-delta git-lfs httpie yq \
        nodejs npm \
        java-25-openjdk-headless maven \
        golang gopls \
        rust cargo clippy rustfmt rust-analyzer cargo-deny \
        python3-pip python3-mypy python3-pytest python3-lsp-server \
        ruff poetry pipx uv black pylint yamllint \
        pnpm yarnpkg \
        just \
        gdb lldb strace ltrace valgrind heaptrack delve \
        shellcheck shfmt \
        gcc gcc-c++ make cmake pkgconfig unzip \
        iproute iputils socat nmap-ncat sqlite \
    && git lfs install --system \
    && microdnf clean all

# ── Agent binaries ─────────────────────────────────────────────
RUN npm install -g --prefix /usr/local \
        opencode-ai@1.16.2 \
        @fission-ai/openspec@1.4.1 \
        @anthropic-ai/claude-code@2.1.168 \
        @openai/codex@0.137.0

# ── Antigravity CLI (agy) ───────────────────────────────────────
# NOT installed at build: the upstream installer is a pipe-to-shell with a floating
# version (violates the image package-source policy + bakes the wrong arch on the
# aarch64 macOS guest). agy installs EVERY_LAUNCH from the Antigravity forge
# entrypoint instead (install-if-missing, timeout-guarded, latest).
# @trace plan/issues/forge-harness-every-launch-latest-2026-07-04.md (order 181)

# ── marksman Markdown LSP server ────────────────────────────────
# Single self-contained .NET binary from GitHub releases.
ARG MARKSMAN_VERSION=2026-02-08
RUN curl -LsSf "https://github.com/artempyanykh/marksman/releases/download/${MARKSMAN_VERSION}/marksman-linux-x64" -o /usr/local/bin/marksman \
    && chmod +x /usr/local/bin/marksman

# ── Python packages and developer tools ─────────────────────────
RUN pip3 install --timeout 120 --no-cache-dir \
        pyright==1.1.410 \
        bandit==1.9.2 \
    && npm install -g \
        typescript@6.0.3 \
        typescript-language-server@5.3.0 \
        prettier@3.8.3 \
        eslint@10.4.1 \
        markdownlint-cli@0.48.0

# ── Toolchains (Rust, Go, Dart, etc) ───────────────────────────
ENV CARGO_HOME=/usr/local/cargo \
    PATH=/usr/local/cargo/bin:$PATH

# Cargo dev-tools + nextest (order 188) AND actionlint/vale/wasmtime (order 180
# slice 2) are NO LONGER installed at build — they moved to an arch-aware idempotent
# FIRST_RUN install (lib-common `ensure_forge_prebuilt_tools`), which fixes the
# aarch64 macOS guest baking non-executable x86_64 binaries + the sequential-fetch
# build hang. Only Dart (a full SDK unpacked to /opt/dart-sdk, not a single binary)
# remains build-time for now — its arch-aware first-run migration is a later sub-slice.
ARG DART_VERSION=3.12.1
ARG DART_SHA256=6a2bbf64a133c9c86a62a532dbd3e0b4db4ac365abd456e9f9d1c5df61fcdbf8

RUN set -eux; \
    mkdir -p /usr/local/cargo/bin \
    && curl -LsSf "https://storage.googleapis.com/dart-archive/channels/stable/release/${DART_VERSION}/sdk/dartsdk-linux-x64-release.zip" -o /tmp/dart.zip \
    && echo "${DART_SHA256}  /tmp/dart.zip" | sha256sum -c - \
    && mkdir -p /opt && unzip -q /tmp/dart.zip -d /opt \
    && rm -f /tmp/dart.zip

ENV PATH=/opt/dart-sdk/bin:$PATH
