# Tillandsias Forge — Fedora Minimal Base
# Heavy dependencies cached to improve rapid rebuilds of the final image.
# @trace spec:default-image
# LEAN forge: essential dev tools only. Terminal UX tools (mc, vim, nano, eza, bat, fd-find, fzf, htop, tree, zoxide) removed to save ~90MB.
FROM registry.fedoraproject.org/fedora-minimal:44

# ── System packages ────────────────────────────────────────────
RUN microdnf install -y --setopt=install_weak_deps=0 \
        bash coreutils findutils grep sed gawk tar gzip xz \
        procps-ng shadow-utils ca-certificates ncurses ncurses-term \
        fish zsh \
        git gh curl wget jq ripgrep fd-find bat git-delta git-lfs httpie yq \
        nodejs npm \
        java-25-openjdk-headless maven \
        golang gopls \
        rust cargo clippy rustfmt rust-analyzer cargo-deny \
        python3-pip python3-mypy python3-pytest python3-lsp-server \
        ruff poetry pipx uv black pylint yamllint \
        pnpm yarnpkg \
        just \
        gdb lldb strace ltrace valgrind heaptrack delve \
        shellcheck shfmt \
        gcc gcc-c++ make cmake openssl-devel pkgconfig unzip \
    && git lfs install --system \
    && microdnf clean all

# ── Agent binaries ─────────────────────────────────────────────
RUN npm install -g --prefix /usr/local \
        opencode-ai@1.16.2 \
        @fission-ai/openspec@1.4.1 \
        @anthropic-ai/claude-code@2.1.168 \
        @openai/codex@0.137.0

# ── marksman Markdown LSP server ────────────────────────────────
# Single self-contained .NET binary from GitHub releases.
ARG MARKSMAN_VERSION=2026-02-08
RUN curl -LsSf "https://github.com/artempyanykh/marksman/releases/download/${MARKSMAN_VERSION}/marksman-linux-x64" -o /usr/local/bin/marksman \
    && chmod +x /usr/local/bin/marksman

# ── Python packages and developer tools ─────────────────────────
RUN pip3 install --no-cache-dir \
        pyright==1.1.410 \
        bandit==1.9.2 \
    && npm install -g \
        typescript@6.0.3 \
        typescript-language-server@5.3.0 \
        prettier@3.8.3 \
        eslint@10.4.1 \
        markdownlint-cli@0.48.0

# ── Toolchains (Rust, Go, Dart, etc) ───────────────────────────
ENV CARGO_HOME=/usr/local/cargo \
    PATH=/usr/local/cargo/bin:$PATH

ARG CARGO_NEXTEST_VERSION=0.9.137
ARG WASMTIME_VERSION=45.0.0
ARG ACTIONLINT_VERSION=1.7.12
ARG VALE_VERSION=3.14.2
ARG DART_VERSION=3.12.1

ARG CARGO_NEXTEST_SHA256=38fd6275e111b200bbbed1bd2ae91cbb0d7edd28504879875cff2b3d96f3f311
ARG CARGO_CHEF_SHA256=70ac603582bbf2779d40d2cbac124751ed35325496c72c92d54385c4e4af8e52
ARG CARGO_WATCH_SHA256=f0fc550c004a39d0456ac2b2014bc4a1b7346d8900ac091f0c254ddb382101bb
ARG CARGO_AUDIT_SHA256=a2dc84bc76c3faa1a8115719d62adebe0bd4d65effa83340f0c3f7e2f7012709
ARG WASM_PACK_SHA256=a929959b88d76f541d4e242259f0d5334ef39db4b6dc452137e51a8018e39c85
ARG TRUNK_SHA256=92be02208d6f3b22415314ed8b7aa0d55cc3e047be4d37f8bbe3841ff3b45c06
ARG TYPOS_CLI_SHA256=23861ca40fde6007bd4a88c4c6b6bd0f7974a886225d89f20bf97f5a2fe99dc2
ARG WATCHEXEC_CLI_SHA256=b2c041a443d3af237f45e35d0f5ca5b20f26faa05e95a0ab29211a0aa8b04ee3
ARG CARGO_EDIT_SHA256=6dcd50d77c22b68292436e29634bad211b313cc26f849ffcf33cc540ae33177e
ARG CARGO_LLVM_COV_SHA256=9a75fe29538d3800b3da57f6f6efb64cba5c720a257bf0cb8b51f39d495a9168
ARG CARGO_SEMVER_CHECKS_SHA256=fc0144b6cfd8820bdb4180228212c26e6ee6b58363a20849c3386a5d22e90c3d
ARG CARGO_EXPAND_SHA256=62269d2fe935295eb30f34ce87ed1ba3ea81df4630a189456a05530f106dc7ef
ARG CARGO_CRITERION_SHA256=91fe290bcd53e0f8f85616d529297aebb5556097fc413e03e2399907c9fa3e5c
ARG CARGO_WASI_SHA256=9d88aaf77742e3b7e0edb9f59fae71b02eb0f1c86098e1d65c8ead80514f0d76
ARG CARGO_OUTDATED_SHA256=9e6f0195f07b2e13187936589b5a761119a7fc5b984ae0808148994c7bab2cce
ARG WASMTIME_SHA256=9d92e6dc04630f617e0e5d532327a5a917ac4898587e07f4fb7a5fc7fffef760
ARG ACTIONLINT_SHA256=8aca8db96f1b94770f1b0d72b6dddcb1ebb8123cb3712530b08cc387b349a3d8
ARG VALE_SHA256=469cf88ec58a374dca14b2564c4391d2c9a1c632210aa0b642758b794082e05f
ARG DART_SHA256=6a2bbf64a133c9c86a62a532dbd3e0b4db4ac365abd456e9f9d1c5df61fcdbf8

RUN set -eux; \
    install_archive() { \
        name="$1"; url="$2"; checksum="$3"; \
        archive="/tmp/${name}.tar.gz"; \
        curl -LsSf "$url" -o "$archive"; \
        echo "${checksum}  ${archive}" | sha256sum -c -; \
        tar -xzf "$archive" -C /usr/local/bin; \
        rm -f "$archive"; \
    }; \
    mkdir -p /usr/local/cargo/bin \
    # Nextest manual binary install
    && curl -LsSf "https://github.com/nextest-rs/nextest/releases/download/cargo-nextest-${CARGO_NEXTEST_VERSION}/cargo-nextest-${CARGO_NEXTEST_VERSION}-x86_64-unknown-linux-gnu.tar.gz" -o /tmp/cargo-nextest.tar.gz \
    && echo "${CARGO_NEXTEST_SHA256}  /tmp/cargo-nextest.tar.gz" | sha256sum -c - \
    && tar -xzf /tmp/cargo-nextest.tar.gz -C /usr/local/bin \
    # Versioned release assets avoid cargo-binstall's rate-limited GitHub API.
    && install_archive cargo-chef "https://github.com/cargo-bins/cargo-quickinstall/releases/download/cargo-chef-0.1.77/cargo-chef-0.1.77-x86_64-unknown-linux-gnu.tar.gz" "${CARGO_CHEF_SHA256}" \
    && install_archive cargo-watch "https://github.com/cargo-bins/cargo-quickinstall/releases/download/cargo-watch-8.5.3/cargo-watch-8.5.3-x86_64-unknown-linux-gnu.tar.gz" "${CARGO_WATCH_SHA256}" \
    && install_archive cargo-audit "https://github.com/cargo-bins/cargo-quickinstall/releases/download/cargo-audit-0.22.2/cargo-audit-0.22.2-x86_64-unknown-linux-gnu.tar.gz" "${CARGO_AUDIT_SHA256}" \
    && install_archive wasm-pack "https://github.com/cargo-bins/cargo-quickinstall/releases/download/wasm-pack-0.15.0/wasm-pack-0.15.0-x86_64-unknown-linux-gnu.tar.gz" "${WASM_PACK_SHA256}" \
    && install_archive trunk "https://github.com/trunk-rs/trunk/releases/download/v0.22.0-beta.1/trunk-x86_64-unknown-linux-gnu.tar.gz" "${TRUNK_SHA256}" \
    && install_archive typos-cli "https://github.com/cargo-bins/cargo-quickinstall/releases/download/typos-cli-1.47.2/typos-cli-1.47.2-x86_64-unknown-linux-gnu.tar.gz" "${TYPOS_CLI_SHA256}" \
    && install_archive watchexec-cli "https://github.com/cargo-bins/cargo-quickinstall/releases/download/watchexec-cli-2.5.1/watchexec-cli-2.5.1-x86_64-unknown-linux-gnu.tar.gz" "${WATCHEXEC_CLI_SHA256}" \
    && install_archive cargo-edit "https://github.com/cargo-bins/cargo-quickinstall/releases/download/cargo-edit-0.13.11/cargo-edit-0.13.11-x86_64-unknown-linux-musl.tar.gz" "${CARGO_EDIT_SHA256}" \
    && install_archive cargo-llvm-cov "https://github.com/taiki-e/cargo-llvm-cov/releases/download/v0.8.7/cargo-llvm-cov-x86_64-unknown-linux-gnu.tar.gz" "${CARGO_LLVM_COV_SHA256}" \
    && install_archive cargo-semver-checks "https://github.com/obi1kenobi/cargo-semver-checks/releases/download/v0.48.0/cargo-semver-checks-x86_64-unknown-linux-gnu.tar.gz" "${CARGO_SEMVER_CHECKS_SHA256}" \
    && install_archive cargo-expand "https://github.com/cargo-bins/cargo-quickinstall/releases/download/cargo-expand-1.0.122/cargo-expand-1.0.122-x86_64-unknown-linux-gnu.tar.gz" "${CARGO_EXPAND_SHA256}" \
    && install_archive cargo-criterion "https://github.com/cargo-bins/cargo-quickinstall/releases/download/cargo-criterion-1.1.0/cargo-criterion-1.1.0-x86_64-unknown-linux-gnu.tar.gz" "${CARGO_CRITERION_SHA256}" \
    && install_archive cargo-wasi "https://github.com/cargo-bins/cargo-quickinstall/releases/download/cargo-wasi-0.1.28/cargo-wasi-0.1.28-x86_64-unknown-linux-gnu.tar.gz" "${CARGO_WASI_SHA256}" \
    && install_archive cargo-outdated "https://github.com/cargo-bins/cargo-quickinstall/releases/download/cargo-outdated-0.19.0/cargo-outdated-0.19.0-x86_64-unknown-linux-gnu.tar.gz" "${CARGO_OUTDATED_SHA256}" \
    && install_archive actionlint "https://github.com/rhysd/actionlint/releases/download/v${ACTIONLINT_VERSION}/actionlint_${ACTIONLINT_VERSION}_linux_amd64.tar.gz" "${ACTIONLINT_SHA256}" \
    && install_archive vale "https://github.com/errata-ai/vale/releases/download/v${VALE_VERSION}/vale_${VALE_VERSION}_Linux_64-bit.tar.gz" "${VALE_SHA256}" \
    # Wasmtime and Dart
    && curl -LsSf "https://github.com/bytecodealliance/wasmtime/releases/download/v${WASMTIME_VERSION}/wasmtime-v${WASMTIME_VERSION}-x86_64-linux.tar.xz" -o /tmp/wasmtime.tar.xz \
    && echo "${WASMTIME_SHA256}  /tmp/wasmtime.tar.xz" | sha256sum -c - \
    && tar -xJf /tmp/wasmtime.tar.xz --strip-components=1 -C /usr/local/bin "wasmtime-v${WASMTIME_VERSION}-x86_64-linux/wasmtime" \
    && curl -LsSf "https://storage.googleapis.com/dart-archive/channels/stable/release/${DART_VERSION}/sdk/dartsdk-linux-x64-release.zip" -o /tmp/dart.zip \
    && echo "${DART_SHA256}  /tmp/dart.zip" | sha256sum -c - \
    && mkdir -p /opt && unzip -q /tmp/dart.zip -d /opt \
    && rm -f /tmp/wasmtime.tar.xz /tmp/dart.zip /tmp/cargo-nextest.tar.gz

ENV PATH=/opt/dart-sdk/bin:$PATH
