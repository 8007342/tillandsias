#!/usr/bin/env bash
# tillandsias-services — print the discoverable enclave services + status.
# Hardcoded list: the agent needs a SOURCE OF TRUTH for what is reachable
# from the forge. Status is checked with `nc -z` (1s timeout), or bash's
# /dev/tcp fallback if nc is missing.
#
# Usage: tillandsias-services [--json]
#
# @trace spec:forge-environment-discoverability
# @cheatsheet runtime/forge-paths-ephemeral-vs-persistent.md, runtime/forge-container.md

set -euo pipefail

JSON=0
case "${1:-}" in
    --json) JSON=1 ;;
    -h|--help) sed -n '2,9p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    "") ;;
    *) echo "tillandsias-services: unknown arg '$1'" >&2
       echo "usage: tillandsias-services [--json]" >&2; exit 2 ;;
esac

# Service catalogue — name|host|port|protocol|description|hint
SERVICES=(
    "proxy|proxy|3128|http-connect|caching HTTP/S proxy (Squid, allowlisted domains)|set HTTP_PROXY=http://proxy:3128"
    "git-service|git-service|9418|git|bare mirror + auto-push to remote|git clone git://git-service/<project>"
    "inference|inference|11434|http|local ollama API|curl http://inference:11434/api/tags"
)

# Per-project router (host-side; not enclave-resolvable from the forge).
ROUTER_HOST="opencode.<project>.localhost"
ROUTER_PORT=8080
ROUTER_DESC="per-project router (open from host browser)"

probe() {
    local host="$1" port="$2"
    if command -v nc >/dev/null 2>&1; then
        nc -z -w 1 "$host" "$port" 2>/dev/null && { printf 'up'; return; }
    elif (exec 3<>"/dev/tcp/$host/$port") 2>/dev/null; then
        exec 3<&- 3>&-; printf 'up'; return
    fi
    printf 'unreachable'
}

emit_text() {
    printf 'Tillandsias enclave services\n\n'
    printf '  %-13s %-26s %-12s %-12s %s\n' NAME ADDRESS STATUS PROTOCOL DESCRIPTION
    local entry name host port proto desc hint status
    for entry in "${SERVICES[@]}"; do
        IFS='|' read -r name host port proto desc hint <<<"$entry"
        status="$(probe "$host" "$port")"
        printf '  %-13s %-26s %-12s %-12s %s\n' \
            "$name" "${host}:${port}" "$status" "$proto" "$desc"
    done
    printf '  %-13s %-26s %-12s %-12s %s\n' \
        "router" "${ROUTER_HOST}:${ROUTER_PORT}" "host-only" "http" "$ROUTER_DESC"
    printf '\nHints\n'
    for entry in "${SERVICES[@]}"; do
        IFS='|' read -r name host port proto desc hint <<<"$entry"
        printf '  %-13s %s\n' "$name" "$hint"
    done
}

emit_json() {
    local entry name host port proto desc hint status tsv=""
    for entry in "${SERVICES[@]}"; do
        IFS='|' read -r name host port proto desc hint <<<"$entry"
        status="$(probe "$host" "$port")"
        tsv+="${name}"$'\t'"${host}"$'\t'"${port}"$'\t'"${proto}"$'\t'"${status}"$'\t'"${desc}"$'\t'"${hint}"$'\n'
    done
    local services_json
    services_json="$(printf '%s' "$tsv" | jq -Rs 'split("\n")
        | map(select(length>0)) | map(split("\t") | {
            name: .[0], host: .[1], port: (.[2]|tonumber),
            protocol: .[3], status: .[4], description: .[5], hint: .[6]
        })')"
    jq -n --argjson services "$services_json" \
        --arg router_host "$ROUTER_HOST" \
        --argjson router_port "$ROUTER_PORT" \
        --arg router_desc "$ROUTER_DESC" \
        '{services: $services, router: {
            host: $router_host, port: $router_port,
            status: "host-only", protocol: "http",
            description: $router_desc
        }}'
}

if [ $JSON -eq 1 ]; then emit_json; else emit_text; fi
