# Force LF line endings for all text files in the repo.
# This overrides core.autocrlf on Windows machines, ensuring
# include_str!() embeds LF (not CRLF) in the binary.
* text=auto eol=lf

# Explicitly mark binary formats
*.png binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# cheatsheet-sources: LFS-track verbatim HTML and PDF payloads.
# Even if LFS is not installed, this entry is harmless — it just won't filter.
# @trace spec:cheatsheet-source-layer
cheatsheet-sources/**/*.html filter=lfs diff=lfs merge=lfs -text
cheatsheet-sources/**/*.pdf filter=lfs diff=lfs merge=lfs -text
