#!/usr/bin/env bash
set -euo pipefail

# Repo-local Codex launcher for Tillandsias.
#
# One-shot TUI:
#   ./codex "prompt"
#
# One-shot unattended:
#   ./codex --quiet "prompt"
#
# Unattended loops are handled by ./repeat:
#   ./repeat --agent codex --prompt "Use the /meta-orchestration skill"

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(git -C "$script_dir" rev-parse --show-toplevel 2>/dev/null || printf '%s\n' "$script_dir")"
cd "$repo_root"

CODEX_BIN="${CODEX_BIN:-}"
if [[ -z "$CODEX_BIN" ]]; then
  if [[ -x "${HOME}/.npm-global/bin/codex" ]]; then
    CODEX_BIN="${HOME}/.npm-global/bin/codex"
  else
    CODEX_BIN="$(command -v codex 2>/dev/null || true)"
  fi
fi
if [[ -z "$CODEX_BIN" || ! -x "$CODEX_BIN" ]]; then
  printf 'codex: unable to find executable codex binary. Set CODEX_BIN=/path/to/codex.\n' >&2
  exit 127
fi

export CODEX_PROJECT_ROOT="$repo_root"
repo_codex_profile="$repo_root/.codex/tillandsias.profile.sh"

QUIET=0
TRUSTED_EXEC="${CODEX_TRUSTED_EXEC:-0}"
codex_args=()

usage() {
  cat >&2 <<'EOF'
Usage:
  ./codex [--quiet] "prompt"

Options:
  --quiet, -q          Run `codex exec` once instead of launching the TUI.
  --trusted           Run `codex exec` without Codex's sandbox/approval layer.
                      Intended for unattended coordination loops that must
                      fetch, rebase, commit, and push.
  --                  End wrapper options.

Use ./repeat --agent codex --prompt "..." for recurring unattended runs.
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --quiet|-q)
      QUIET=1
      shift
      ;;
    --trusted)
      TRUSTED_EXEC=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    --)
      shift
      codex_args+=("$@")
      break
      ;;
    *)
      codex_args+=("$1")
      shift
      ;;
  esac
done

if [[ ${#codex_args[@]} -eq 0 ]]; then
  usage
  exit 2
fi

if [[ ${#codex_args[@]} -eq 1 && "${codex_args[0]}" == "/coordinate-multihost-work" ]]; then
  TRUSTED_EXEC=1
  codex_args=("Use the coordinate-multihost-work skill to run one Tillandsias multi-host coordination loop.")
fi

common_args=(-p tillandsias)
profile_additional_args=()
profile_additional_dir_args=()
codex_profile_args=()
codex_profile_add_dirs=()

if [[ -f "$repo_codex_profile" ]]; then
  # shellcheck disable=SC1090
  source "$repo_codex_profile"
fi
if (( ${#codex_profile_args[@]} > 0 )); then
  profile_additional_args+=("${codex_profile_args[@]}")
fi
if (( ${#codex_profile_add_dirs[@]} > 0 )); then
  for dir in "${codex_profile_add_dirs[@]}"; do
    profile_additional_dir_args+=(--add-dir "$dir")
  done
fi

timestamp_utc() {
  date -u '+%Y-%m-%dT%H:%M:%SZ'
}

timestamp_pacific_from_epoch() {
  local epoch="$1"
  TZ=America/Los_Angeles date -d "@$epoch" '+%Y-%m-%d %H:%M:%S %Z'
}

run_tui_once() {
  "$CODEX_BIN" \
    "${common_args[@]}" \
    "${profile_additional_args[@]}" \
    "${profile_additional_dir_args[@]}" \
    "${codex_args[@]}"
}

run_exec_once() {
  local trusted_args=()
  if [[ "$TRUSTED_EXEC" == "1" || "$TRUSTED_EXEC" == "true" || "$TRUSTED_EXEC" == "yes" ]]; then
    trusted_args=(--dangerously-bypass-approvals-and-sandbox)
  fi
  "$CODEX_BIN" \
    exec \
    --color never \
    "${trusted_args[@]}" \
    "${common_args[@]}" \
    "${profile_additional_args[@]}" \
    "${profile_additional_dir_args[@]}" \
    "${codex_args[@]}"
}

if [[ "$QUIET" -eq 1 ]]; then
  run_exec_once
else
  run_tui_once
fi
