#!/usr/bin/env bash
set -euo pipefail

CODEX_BIN="${CODEX_BIN:-${HOME}/.npm-global/bin/codex}"
if [[ ! -x "$CODEX_BIN" ]]; then
  CODEX_BIN="$(command -v codex)"
fi

QUIET=0
VERBOSE=0
REPEAT_INTERVAL=""
codex_args=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --quiet|-q)
      QUIET=1
      shift
      ;;
    --verbose|-v)
      VERBOSE=1
      shift
      ;;
    --repeat)
      if [[ $# -lt 2 ]]; then
        printf 'codex: --repeat requires an interval such as 30m or 2h30m\n' >&2
        exit 2
      fi
      REPEAT_INTERVAL="$2"
      shift 2
      ;;
    --)
      shift
      codex_args+=("$@")
      break
      ;;
    *)
      codex_args+=("$1")
      shift
      ;;
  esac
done

common_args=(
  -p tillandsias
  -c 'profiles.tillandsias.writable_roots=["/run/user/1000","/var/home/machiyotl"]'
)

progress_bar() {
  local value="${1:-0}"
  local width="${2:-10}"
  local filled=$(( value * width / 100 ))
  local empty=$(( width - filled ))
  local bar=""
  local i
  for ((i = 0; i < filled; i++)); do
    bar+="█"
  done
  for ((i = 0; i < empty; i++)); do
    bar+="░"
  done
  printf '%s' "$bar"
}

sparkline_char() {
  local value="${1:-0}"
  case $(( value * 7 / 100 )) in
    0) printf '▁' ;;
    1) printf '▂' ;;
    2) printf '▃' ;;
    3) printf '▄' ;;
    4) printf '▅' ;;
    5) printf '▆' ;;
    6) printf '▇' ;;
    *) printf '█' ;;
  esac
}

sparkline_for_values() {
  local value
  for value in "$@"; do
    sparkline_char "$value"
  done
}

format_elapsed() {
  local total="${1:-0}"
  local hours=$(( total / 3600 ))
  local minutes=$(( (total % 3600) / 60 ))
  local seconds=$(( total % 60 ))
  if [[ "$hours" -gt 0 ]]; then
    printf '%02d:%02d:%02d' "$hours" "$minutes" "$seconds"
  else
    printf '%02d:%02d' "$minutes" "$seconds"
  fi
}

format_timestamp() {
  local epoch="${1:-0}"
  date -d "@$epoch" '+%H:%M:%S'
}

if [[ "$VERBOSE" -eq 1 ]]; then
  exec "$CODEX_BIN" \
    "${common_args[@]}" \
    "${codex_args[@]}"
fi

if [[ -n "$REPEAT_INTERVAL" ]]; then
  REPEAT_SUPERVISOR_BIN="$PWD/target/debug/tillandsias-repeat-loop"
  REPEAT_RENDERER_BIN="$PWD/target/debug/tillandsias-repeat-graph"
  if [[ ! -x "$REPEAT_SUPERVISOR_BIN" || ! -x "$REPEAT_RENDERER_BIN" ]]; then
    cargo build --quiet --offline --manifest-path "$PWD/crates/tillandsias-repeat-graph/Cargo.toml"
  fi
  if [[ ! -x "$REPEAT_SUPERVISOR_BIN" ]]; then
    printf '[codex-repeat] unable to locate repeat supervisor binary: %s\n' "$REPEAT_SUPERVISOR_BIN" >&2
    exit 2
  fi
  exec "$REPEAT_SUPERVISOR_BIN" \
    --prompt "${codex_args[*]}" \
    --interval "$REPEAT_INTERVAL" \
    --codex-bin "$CODEX_BIN" \
    --renderer-bin "$REPEAT_RENDERER_BIN" \
    --state-root "${CODEX_REPEAT_STATE_DIR:-${PWD}/plan/localwork/codex-repeat}" \
    --plan-root "$PWD/plan" \
    --trend-window "${CODEX_REPEAT_TREND_WINDOW:-5}" \
    --refresh-secs "${CODEX_REPEAT_REFRESH_SECS:-2}"
fi

if [[ "$QUIET" -eq 1 ]]; then
  exec "$CODEX_BIN" \
    exec \
    --color never \
    "${common_args[@]}" \
    "${codex_args[@]}"
fi

exec "$CODEX_BIN" \
  "${common_args[@]}" \
  "${codex_args[@]}"
